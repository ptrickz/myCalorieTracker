// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum GoalType {
  LOSE
  MAINTAIN
  GAIN
}

enum FoodSource {
  OPEN_FOOD_FACTS
  MYFCD
  CUSTOM
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  dateOfBirth   DateTime?
  sex           Sex?
  heightCm      Float?
  activityLevel ActivityLevel?
  goalType      GoalType?
  goalWeightKg      Float?
  milestoneWeightKg Float?
  proteinTargetG    Float?

  // Desired weekly weight-change pace (kg/week, 0.25-1.0 in 0.25 steps).
  // Drives the calorie adjustment: deficitPerDay = weeklyLossGoalKg * 7700 / 7,
  // subtracted for LOSE and added for GAIN.
  weeklyLossGoalKg Float @default(0.5)

  // When false (default), weekday and weekend calorie targets are both the
  // auto-calculated TDEE target. When true, the two override fields below
  // are used instead (falling back to the auto target if left unset).
  useCustomCalorieTargets Boolean @default(false)
  weekdayTargetCalories   Float?
  weekendTargetCalories   Float?

  // Rolling 24h rate limit for the vision-log endpoint (Claude vision calls
  // cost real money per request). Resets when the window expires.
  visionLogCount           Int      @default(0)
  visionLogWindowStartedAt DateTime?

  weightLogs      WeightLog[]
  logEntries      LogEntry[]
  foodItems       FoodItem[]
  createdExercises Exercise[]
  workoutLogs     WorkoutLog[]
}

model WeightLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  weightKg   Float
  recordedAt DateTime @default(now())

  @@index([userId, recordedAt])
}

model FoodItem {
  id               String     @id @default(uuid())
  name             String
  caloriesPer100g  Float
  proteinPer100g   Float
  carbsPer100g     Float
  fatPer100g       Float
  barcode          String?    @unique
  source           FoodSource
  photoBase64      String?
  createdByUserId  String?
  createdBy        User?      @relation(fields: [createdByUserId], references: [id])
  createdAt        DateTime   @default(now())

  logEntries LogEntry[]

  @@index([name])
}

model LogEntry {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  foodItemId    String
  foodItem      FoodItem @relation(fields: [foodItemId], references: [id])
  servingGrams  Float
  mealType      MealType
  loggedAt      DateTime @default(now())

  // Snapshot of the food's macros at the time of logging, scaled to servingGrams,
  // so later edits to FoodItem don't retroactively change historical logs.
  calories Float
  protein  Float
  carbs    Float
  fat      Float

  @@index([userId, loggedAt])
}

// Exercise catalog: seeded entries (createdByUserId null) from the user's
// actual routine, plus any custom exercises created for gym/sport sessions
// that aren't part of that fixed program.
model Exercise {
  id              String   @id @default(uuid())
  name            String
  formCue         String?
  videoUrl        String?
  imageUrl        String?
  // Which day of the seeded routine this belongs to ("Monday" / "Wednesday" /
  // "Friday"), or null for custom/freeform exercises not tied to a fixed day.
  dayTag          String?
  defaultSets     Int?
  // Free text since targets are a mix of rep ranges and durations, e.g.
  // "8-10", "3x12", "20-30 sec".
  defaultReps     String?
  createdByUserId String?
  createdBy       User?    @relation(fields: [createdByUserId], references: [id])
  createdAt       DateTime @default(now())

  setLogs WorkoutSetLog[]

  @@index([name])
}

model WorkoutLog {
  id       String   @id @default(uuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  // Free text ("Home", "Gym", "Badminton court", ...) rather than an enum —
  // real training spans more contexts than one fixed home routine.
  venue    String
  loggedAt DateTime @default(now())
  notes    String?

  sets WorkoutSetLog[]

  @@index([userId, loggedAt])
}

model WorkoutSetLog {
  id              String     @id @default(uuid())
  workoutLogId    String
  workoutLog      WorkoutLog @relation(fields: [workoutLogId], references: [id])
  exerciseId      String
  exercise        Exercise   @relation(fields: [exerciseId], references: [id])
  setNumber       Int
  reps            Int?
  weightKg        Float?
  durationSeconds Int?
  completedAt     DateTime   @default(now())

  @@index([exerciseId, completedAt])
}
